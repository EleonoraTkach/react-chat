import { useContext } from "react";
import { ChatContext } from "./ChatContext";

export const ChatItem = ({ chat, isActive }: ChatItemProps) => {
  const { dispatch } = useContext(ChatContext);

  return (
    <div
      className={`chat-item ${isActive ? "active" : ""}`}
      onClick={() =>
        dispatch({ type: "SET_ACTIVE_CHAT", payload: chat.id })
      }
    >
      <div className="chat-content">
        <div className="chat-title">{chat.title}</div>
      </div>

      <div className="chat-actions">
        <button
          onClick={(e) => {
            e.stopPropagation();
            const title = prompt("Новое название") || chat.title;
            dispatch({
              type: "RENAME_CHAT",
              payload: { id: chat.id, title },
            });
          }}
        >
          ✏️
        </button>

        <button
          onClick={(e) => {
            e.stopPropagation();
            if (confirm("Удалить чат?")) {
              dispatch({ type: "DELETE_CHAT", payload: chat.id });
            }
          }}
        >
          🗑️
        </button>
      </div>
    </div>
  );
};