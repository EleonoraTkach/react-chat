:root {
  --color-bg: #ffffff;
  --color-text: #111111;
  --color-primary: #3b82f6;
  --color-secondary: #f1f1f1;
  --color-border: #e5e7eb;
}

[data-theme="dark"] {
  --color-bg: #1a1a1a;
  --color-text: #f5f5f5;
  --color-primary: #2563eb;
  --color-secondary: #2a2a2a;
  --color-border: #333;
}

/* база */
body {
  background: var(--color-bg);
  color: var(--color-text);
  margin: 0;
  font-family: sans-serif;
}